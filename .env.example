# Avatar AI styling — three supported setups.
#
# IMPORTANT: copy any sensitive value into a `*.local` file (gitignored). Vite
# loads them as follows:
#   `.env.development.local`  → only `vite dev` / `npm run dev`
#   `.env.production.local`   → only `vite build` / `npm run deploy`
#   `.env.local`              → both (avoid for secrets)

# --------------------------------------------------------------------
# Option A — local prototyping only: call OpenAI directly from the browser.
# WARNING: any non-empty value here is inlined into the JS bundle. Never set
# this in `.env.production*` or in CI for a public deploy — the key would leak.
# Recommended file: `.env.development.local`
# --------------------------------------------------------------------
VITE_OPENAI_API_KEY=

# --------------------------------------------------------------------
# Option B — production: send uploads to the password-gated Cloudflare Worker
# in `cf-worker/`. The Worker holds the real OpenAI key and validates a shared
# password the user types into the Unlock card on the Avatar page.
#
# Endpoint contract (matches `cf-worker/src/index.ts`):
#   POST <endpoint>
#   Authorization: Bearer <password>
#   multipart/form-data { image, prompt, size?, model? }
#   → image/png binary on 200; { error } JSON otherwise.
#
# Recommended file: `.env.production.local`, e.g.
#   VITE_AVATAR_GEN_ENDPOINT=https://tinsleytoolbox-avatar-proxy.<account>.workers.dev
# --------------------------------------------------------------------
VITE_AVATAR_GEN_ENDPOINT=
